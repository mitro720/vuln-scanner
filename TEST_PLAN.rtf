{\pard\sb200\sa200\b\fs28 4. TEST CASES\par}

{\pard\sb100\b\fs24 4.1 Unit Test Suite\par}

{\pard\sb50\b TC-U001: CVE Retrieval Validation\par}
{\pard\li360 \bullet  \b Module:\b0  cve_client.py::NVDClient.get_cve_by_id\par}
{\pard\li360 \bullet  \b Objective:\b0  Verify accurate CVE data retrieval from NVD API\par}
{\pard\li360 \bullet  \b Test Data:\b0  CVE-2021-44228 (Log4Shell)\par}
{\pard\li360 \bullet  \b Expected Outcome:\b0  Correct CVE metadata including severity (CRITICAL), CVSS score (10.0)\par}
{\pard\li360 \bullet  \b Status:\b0  \cf2 Passed\cf0\par}

{\pard\sb50\b TC-U002: Version Detection Accuracy\par}
{\pard\li360 \bullet  \b Module:\b0  version_detector.py::VersionDetector.detect_version\par}
{\pard\li360 \bullet  \b Objective:\b0  Validate HTTP server version extraction\par}
{\pard\li360 \bullet  \b Expected Outcome:\b0  Accurate version, banner, and product identification\par}
{\pard\li360 \bullet  \b Status:\b0  \cf2 Passed\cf0\par}

{\pard\sb50\b TC-U003: CVE Matching Algorithm\par}
{\pard\li360 \bullet  \b Module:\b0  cve_matcher.py::CVEMatcher.match_service\par}
{\pard\li360 \bullet  \b Test Data:\b0  Apache 2.4.49 (CVE-2021-41773, CVE-2021-42013)\par}
{\pard\li360 \bullet  \b Expected Outcome:\b0  Correct CVE identification with remediation guidance\par}
{\pard\li360 \bullet  \b Status:\b0  \cf2 Passed\cf0\par}

{\pard\sb50\b TC-U004: Rate Limiting Enforcement\par}
{\pard\li360 \bullet  \b Module:\b0  cve_client.py::RateLimiter.wait_if_needed\par}
{\pard\li360 \bullet  \b Expected Outcome:\b0  Automatic throttling after threshold reached\par}
{\pard\li360 \bullet  \b Status:\b0  \cf2 Passed\cf0\par}
\par

